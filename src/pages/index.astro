---
import '../styles/global.css';
---
<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><meta name="theme-color" content="#090a09"><link rel="icon" href="/favicon.svg"><title>Second Key</title><script src="https://shoo.dev/shoo.js" defer></script></head>
<body class="min-h-screen bg-ink text-paper">
<header class="sticky top-0 z-30 border-b border-line bg-ink/90 backdrop-blur-xl"><div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8"><a href="/" class="flex items-center gap-3 no-underline"><span class="grid size-10 place-items-center bg-acid font-display text-xl text-ink">Ⅱ</span><span class="font-display text-lg tracking-tight">SECOND KEY</span></a><div class="flex items-center gap-3"><a id="identity" href="https://shoo.dev/me" target="_blank" class="hidden items-center gap-3 border-r border-line pr-4 text-right no-underline"><span><b id="name" class="block text-xs">User</b><small class="text-[9px] uppercase tracking-widest text-white/40">Manage profile ↗</small></span><span id="avatar" class="grid size-9 place-items-center border border-white/20 text-xs text-acid">SK</span></a><button id="logout" class="hidden bg-transparent px-2 py-2 text-xs text-white/50 hover:text-white">Sign out</button></div></div></header>
<main class="mx-auto max-w-7xl px-5 py-10 lg:px-8 lg:py-16">  <section id="gate" class="grid min-h-[65vh] place-items-center"><div class="w-full max-w-md border border-line bg-[#10120f] p-7 shadow-[10px_10px_0_#1d211a]"><p class="mb-4 text-[10px] uppercase tracking-[.22em] text-acid">Private authenticator</p><h1 class="font-display text-4xl leading-[.95] tracking-[-.055em]">Codes without<br>the clutter.</h1><p class="mt-5 text-sm leading-6 text-white/50">Encrypted TOTP storage, protected by your Google identity.</p><p id="authError" class="mt-5 hidden border-l-2 border-red-400 bg-red-400/10 p-3 text-xs text-red-200"></p><button id="login" class="mt-8 w-full bg-acid px-5 py-4 font-bold text-ink transition hover:translate-x-1 hover:translate-y-1">Continue with Google →</button></div></section>
  <section id="app" class="hidden"><div class="mb-8 flex flex-wrap items-end justify-between gap-5"><div><p class="text-[10px] uppercase tracking-[.22em] text-acid">Authenticator vault</p><h1 class="mt-2 font-display text-5xl tracking-[-.06em]">Your codes</h1></div><div class="flex gap-2"><button id="privacy" class="border border-line px-4 py-3 text-xs hover:border-acid">Show codes</button><button id="add" class="bg-acid px-5 py-3 font-bold text-ink">Add token +</button></div></div><div id="list" class="border-t border-line"></div></section>
</main>
<dialog id="modal" class="w-[min(560px,calc(100%-24px))] border border-line bg-[#11130f] p-0 text-paper backdrop:bg-black/80"><form id="form" class="grid gap-4 p-6"><div class="flex items-center justify-between border-b border-line pb-4"><b>Add authenticator</b><button type="button" id="close" class="text-white/50">×</button></div><label class="grid gap-2 text-[10px] uppercase tracking-widest text-white/45">otpauth URI<input id="uri" class="border border-line bg-ink p-3 text-sm normal-case text-paper" placeholder="otpauth://totp/..."></label><div class="grid grid-cols-2 gap-3"><label class="grid gap-2 text-[10px] uppercase tracking-widest text-white/45">Label<input id="label" required class="border border-line bg-ink p-3 text-sm normal-case text-paper"></label><label class="grid gap-2 text-[10px] uppercase tracking-widest text-white/45">Issuer<input id="issuer" class="border border-line bg-ink p-3 text-sm normal-case text-paper"></label></div><label class="grid gap-2 text-[10px] uppercase tracking-widest text-white/45">Base32 secret<input id="secret" required class="border border-line bg-ink p-3 font-mono text-sm normal-case text-paper"></label><div class="grid grid-cols-3 gap-3"><select id="algorithm" class="border border-line bg-ink p-3"><option>SHA1</option><option>SHA256</option><option>SHA512</option></select><select id="digits" class="border border-line bg-ink p-3"><option>6</option><option>8</option></select><select id="period" class="border border-line bg-ink p-3"><option>30</option><option>60</option></select></div><p id="error" class="min-h-4 text-xs text-red-300"></p><button class="bg-acid p-4 font-bold text-ink">Encrypt & save</button></form></dialog><div id="toast" class="pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 translate-y-3 bg-acid px-4 py-3 text-xs font-bold text-ink opacity-0 transition">CODE COPIED</div>
<script>
declare global{interface Window{Shoo:any}};const $=(s:string)=>document.querySelector(s) as any;let items:any[]=[],hidden=true,timer:number;
const req=async(u:string,o:any={}):Promise<any>=>{const r=await fetch(u,{...o,headers:{'content-type':'application/json',...o.headers}});const d:any=await r.json();if(!r.ok)throw Error(d.error);return d};
const b32=(s:string)=>{const a='ABCDEFGHIJKLMNOPQRSTUVWXYZ234567';let b='',o=[];for(const c of s.replace(/[^A-Z2-7]/gi,'').toUpperCase())b+=a.indexOf(c).toString(2).padStart(5,'0');for(let i=0;i+8<=b.length;i+=8)o.push(parseInt(b.slice(i,i+8),2));return new Uint8Array(o)};
async function code(x:any){const n=Math.floor(Date.now()/1000/x.period),m=new Uint8Array(8);new DataView(m.buffer).setBigUint64(0,BigInt(n));const k=await crypto.subtle.importKey('raw',b32(x.secret),{name:'HMAC',hash:'SHA-'+x.algorithm.slice(3)},false,['sign']),h=new Uint8Array(await crypto.subtle.sign('HMAC',k,m)),p=h.at(-1)!&15,v=((h[p]&127)<<24|(h[p+1]&255)<<16|(h[p+2]&255)<<8|(h[p+3]&255))%(10**x.digits);return String(v).padStart(x.digits,'0')}
const esc=(s:string)=>s.replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]!));async function render(){const list=$('#list');if(!items.length){list.innerHTML='<div class="py-24 text-center text-sm text-white/35">No codes yet.</div>';return}list.innerHTML=(await Promise.all(items.map(async x=>{const c=await code(x),left=x.period-Math.floor(Date.now()/1000)%x.period,show=hidden?'•'.repeat(x.digits):c,cut=x.digits/2;return `<article data-code="${c}" class="group grid min-h-32 grid-cols-[1fr_auto_auto] items-center gap-5 border-b border-line py-5 hover:bg-white/[.025] max-md:grid-cols-[1fr_auto]"><div><p class="text-[10px] uppercase tracking-[.18em] text-white/35">${esc(x.issuer||'TOTP')}</p><h2 class="mt-2 font-bold">${esc(x.label)}</h2></div><button data-copy="${c}" class="max-md:order-3 max-md:col-span-2 text-left"><span class="font-display text-4xl tracking-[.08em] md:text-5xl">${show.slice(0,cut)}<i class="px-2 not-italic text-white/15">·</i>${show.slice(cut)}</span><span class="mt-3 block h-0.5 bg-white/10"><i class="block h-full bg-acid" style="width:${left/x.period*100}%"></i></span></button><div class="flex gap-2"><button data-copy="${c}" title="Copy" class="grid size-11 place-items-center border border-line hover:border-acid">⧉</button><button data-delete="${x.id}" title="Delete" class="grid size-11 place-items-center border border-line text-white/35 hover:border-red-400 hover:text-red-300">×</button></div></article>`}))).join('')}
async function copy(c:string){await navigator.clipboard.writeText(c);const t=$('#toast');t.classList.remove('opacity-0','translate-y-3');clearTimeout(timer);timer=setTimeout(()=>t.classList.add('opacity-0','translate-y-3'),1300)};
async function boot(){try{const d=await req('/api/items');items=d.items;$('#gate').classList.add('hidden');$('#app').classList.remove('hidden');$('#identity').classList.remove('hidden');$('#identity').classList.add('flex');$('#logout').classList.remove('hidden');$('#name').textContent=d.name;$('#avatar').textContent=d.name.split(' ').slice(0,2).map((x:string)=>x[0]).join('').toUpperCase();render();setInterval(render,1000)}catch{const i=window.Shoo?.getIdentity();if(i?.token)try{await req('/api/session',{method:'POST',body:JSON.stringify({idToken:i.token})});location.replace('/')}catch(e:any){$('#authError').textContent=e.message;$('#authError').classList.remove('hidden')}}}
$('#login').onclick=()=>window.Shoo?.startSignIn({requestPii:true,returnTo:'/'});$('#logout').onclick=async()=>{await req('/api/logout',{method:'POST'});window.Shoo?.clearIdentity();location.reload()};$('#privacy').onclick=()=>{hidden=!hidden;$('#privacy').textContent=hidden?'Show codes':'Hide codes';render()};$('#add').onclick=()=>($('#modal') as HTMLDialogElement).showModal();$('#close').onclick=()=>($('#modal') as HTMLDialogElement).close();
$('#list').onclick=async (e:any)=>{const t=e.target as HTMLElement,c=t.closest('[data-copy]') as HTMLElement;if(c)return copy(c.dataset.copy!);const d=t.closest('[data-delete]') as HTMLElement;if(d&&confirm('Delete this token?')){await req('/api/items/'+d.dataset.delete,{method:'DELETE'});items=items.filter(x=>x.id!==d.dataset.delete);render()}else{const row=t.closest('[data-code]') as HTMLElement;if(row&&matchMedia('(pointer:coarse)').matches)copy(row.dataset.code!)}};$('#list').ondblclick=(e:any)=>{const r=(e.target as HTMLElement).closest('[data-code]') as HTMLElement;if(r)copy(r.dataset.code!)};
$('#form').onsubmit=async (e:any)=>{e.preventDefault();try{const d=await req('/api/items',{method:'POST',body:JSON.stringify({label:($('#label') as HTMLInputElement).value,issuer:($('#issuer') as HTMLInputElement).value,secret:($('#secret') as HTMLInputElement).value,algorithm:($('#algorithm') as HTMLSelectElement).value,digits:+($('#digits') as HTMLSelectElement).value,period:+($('#period') as HTMLSelectElement).value})});items.push(d.item);($('#modal') as HTMLDialogElement).close();render()}catch(e:any){$('#error').textContent=e.message}};addEventListener('load',boot);
</script></body></html>
