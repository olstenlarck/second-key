---
import { env } from "cloudflare:workers";

import { LoginButton } from "../components/LoginButton";
import { LogoutButton } from "../components/LogoutButton";
import { Vault } from "../components/Vault";
import { getItems, getUser } from "../lib/server";

import "../styles/global.css";

const user = await getUser(Astro.request, env as Env);
const items = user ? await getItems(user.id, env as Env) : [];
const initials = user?.name
  .split(" ")
  .slice(0, 2)
  .map((part) => part[0])
  .join("")
  .toUpperCase();
---

<!doctype html>
<html lang="en" data-authenticated={Boolean(user)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#090a09" />
    <link rel="icon" href="/favicon.svg" />
    <title>Second Key</title>
    <script is:inline src="https://shoo.dev/shoo.js"></script>
    <script is:inline>
      if (
        document.documentElement.dataset.authenticated !== "true" &&
        window.Shoo?.getIdentity().token
      ) {
        document.documentElement.dataset.sessionSync = "true";
      }
    </script>
  </head>
  <body class="min-h-screen bg-ink text-paper">
    <header class="sticky top-0 z-30 border-b border-line bg-ink/90 backdrop-blur-xl">
      <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-5 lg:px-8">
        <a href="/" class="flex items-center gap-3 no-underline">
          <span class="grid size-10 place-items-center bg-acid font-display text-xl text-ink">Ⅱ</span>
          <span class="font-display text-lg tracking-tight">SECOND KEY</span>
        </a>
        {
          user && (
            <div class="flex items-center gap-3">
              <a href="https://shoo.dev/me" target="_blank" rel="noopener" class="flex items-center gap-3 border-r border-line pr-4 text-right no-underline">
                <span>
                  <b class="block text-xs">{user.name}</b>
                  <small class="text-[9px] uppercase tracking-widest text-white/40">Manage profile ↗</small>
                </span>
                <span class="grid size-9 place-items-center border border-white/20 text-xs text-acid">{initials}</span>
              </a>
              <LogoutButton client:load />
            </div>
          )
        }
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-5 py-10 lg:px-8 lg:py-16">
      {
        user ? (
          <Vault client:load initialItems={items} />
        ) : (
          <section class="grid min-h-[65vh] place-items-center">
            <div class="w-full max-w-md border border-line bg-[#10120f] p-7 shadow-[10px_10px_0_#1d211a]">
              <p class="mb-4 text-[10px] uppercase tracking-[.22em] text-acid">Private authenticator</p>
              <h1 class="font-display text-4xl leading-[.95] tracking-[-.055em]">Codes without<br />the clutter.</h1>
              <p class="mt-5 text-sm leading-6 text-white/50">Encrypted TOTP storage, protected by your Google identity.</p>
              <LoginButton client:load />
            </div>
          </section>
        )
      }
    </main>
  </body>
</html>
